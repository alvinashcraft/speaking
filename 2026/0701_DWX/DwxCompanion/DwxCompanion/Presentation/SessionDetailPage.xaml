<UserControl x:Class="DwxCompanion.Presentation.SessionDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DwxCompanion.Presentation"
      xmlns:conv="using:DwxCompanion.Presentation.Converters"
      xmlns:models="using:DwxCompanion.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI">
  <UserControl.Resources>
    <conv:TrackToBrushConverter x:Key="TrackBrush" />
  </UserControl.Resources>
  <ScrollViewer Padding="32"
                Background="#0A0A0A"
                HorizontalScrollMode="Disabled">
    <StackPanel Spacing="24"
                MaxWidth="900"
                HorizontalAlignment="Left">

      <HyperlinkButton Content="← Sessions"
                       Foreground="#C9F04C"
                       FontSize="14"
                       Padding="0"
                       Click="OnBackClick" />

      <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal"
                    Spacing="10">
          <Border Background="{Binding Session.Track, Converter={StaticResource TrackBrush}}"
                  CornerRadius="10"
                  Padding="12,3">
            <TextBlock Text="{Binding Session.Track}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#0A0A0A" />
          </Border>
          <TextBlock Text="{Binding Session.DayLabel}"
                     FontSize="13"
                     Opacity="0.7"
                     VerticalAlignment="Center"
                     Foreground="#E6E8EC" />
        </StackPanel>

        <TextBlock Text="{Binding Session.Title}"
                   FontSize="32"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Foreground="#F5F5F5" />

        <StackPanel Orientation="Horizontal"
                    Spacing="20">
          <TextBlock FontSize="13"
                     Opacity="0.75"
                     Foreground="#E6E8EC">
            <Run Text="🕒 " />
            <Run Text="{Binding TimeRange}" />
          </TextBlock>
          <TextBlock FontSize="13"
                     Opacity="0.75"
                     Foreground="#E6E8EC">
            <Run Text="📍 " />
            <Run Text="{Binding Session.RoomId}" />
          </TextBlock>
        </StackPanel>

        <Button Background="#181818"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                Foreground="#F5F5F5"
                Padding="14,8"
                CornerRadius="20"
                HorizontalAlignment="Left"
                Margin="0,4,0,0"
                Command="{Binding ToggleFavorite}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock FontSize="14">
              <TextBlock.Text>
                <Binding Path="IsFavorite">
                  <Binding.Converter>
                    <conv:BoolToStarConverter />
                  </Binding.Converter>
                </Binding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock FontSize="13">
              <TextBlock.Text>
                <Binding Path="IsFavorite">
                  <Binding.Converter>
                    <conv:BoolToAgendaLabelConverter />
                  </Binding.Converter>
                </Binding>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </Button>
      </StackPanel>

      <Border Background="#181818"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="12"
              Padding="20">
        <TextBlock Text="{Binding Session.Summary}"
                   FontSize="14"
                   LineHeight="22"
                   TextWrapping="Wrap"
                   Foreground="#E6E8EC" />
      </Border>

      <StackPanel Spacing="12">
        <TextBlock Text="Speakers"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#F5F5F5" />
        <ItemsControl ItemsSource="{Binding Speakers}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:Speaker">
              <Border Background="#181818"
                      BorderBrush="#2A2A2A"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="16"
                      Margin="0,0,0,8">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0"
                          Width="56"
                          Height="56"
                          CornerRadius="28"
                          Background="#C9F04C"
                          Margin="0,0,16,0">
                    <TextBlock Text="{Binding Initials}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#0A0A0A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center"
                              Spacing="2">
                    <TextBlock Text="{Binding Name}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F5F5F5" />
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               Opacity="0.7"
                               Foreground="#E6E8EC"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
