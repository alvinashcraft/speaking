<UserControl x:Class="DwxCompanion.Presentation.SpeakersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DwxCompanion.Presentation"
      xmlns:models="using:DwxCompanion.Models"
      xmlns:utu="using:Uno.Toolkit.UI">
  <Grid utu:SafeArea.Insets="VisibleBounds"
        Padding="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <StackPanel Spacing="4"
                Margin="0,0,0,20">
      <TextBlock Text="Speakers"
                 FontSize="32"
                 FontWeight="SemiBold"
                 Foreground="#E6E8EC" />
      <TextBlock Text="Meet the experts presenting at DWX 2026"
                 FontSize="14"
                 Opacity="0.7"
                 Foreground="#E6E8EC" />
    </StackPanel>

    <ListView Grid.Row="1"
              ItemsSource="{Binding Speakers}"
              SelectionMode="Single"
              IsItemClickEnabled="True"
              utu:CommandExtensions.Command="{Binding OpenSpeaker}"
              Background="Transparent"
              Padding="0"
              ScrollViewer.HorizontalScrollMode="Disabled"
              ScrollViewer.VerticalScrollBarVisibility="Auto">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="HorizontalContentAlignment"
                  Value="Stretch" />
          <Setter Property="Padding"
                  Value="0" />
          <Setter Property="Margin"
                  Value="0,0,0,12" />
          <Setter Property="Background"
                  Value="Transparent" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="models:Speaker">
          <Border Background="#181818"
                  BorderBrush="#2A2A2A"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="16">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0"
                      Width="72"
                      Height="72"
                      CornerRadius="36"
                      Background="#C9F04C"
                      VerticalAlignment="Top"
                      Margin="0,0,16,0">
                <TextBlock Text="{Binding Initials}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#0A0A0A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>

              <StackPanel Grid.Column="1"
                          Spacing="4"
                          VerticalAlignment="Top">
                <TextBlock Text="{Binding Name}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F5F5F5"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding Title}"
                           FontSize="12"
                           Opacity="0.75"
                           Foreground="#E6E8EC"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding Bio}"
                           FontSize="12"
                           Opacity="0.55"
                           Foreground="#E6E8EC"
                           TextWrapping="Wrap"
                           MaxLines="3"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,6,0,0" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>
</UserControl>
