<UserControl x:Class="DwxCompanion.Presentation.MyAgendaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DwxCompanion.Presentation"
      xmlns:conv="using:DwxCompanion.Presentation.Converters"
      xmlns:models="using:DwxCompanion.Models"
      xmlns:utu="using:Uno.Toolkit.UI">
  <UserControl.Resources>
    <conv:TrackToBrushConverter x:Key="TrackBrush" />
  </UserControl.Resources>
  <Grid utu:SafeArea.Insets="VisibleBounds"
        Padding="24"
        Background="#0A0A0A">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <StackPanel Spacing="4"
                Margin="0,0,0,20">
      <TextBlock Text="My Agenda"
                 FontSize="32"
                 FontWeight="SemiBold"
                 Foreground="#F5F5F5" />
      <TextBlock Text="Your favorited sessions for DWX 2026"
                 FontSize="14"
                 Opacity="0.7"
                 Foreground="#E6E8EC" />
    </StackPanel>

    <Grid Grid.Row="1">
      <ListView ItemsSource="{Binding Sessions}"
                SelectionMode="None"
                Background="Transparent"
                Padding="0"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0,0,0,12" />
            <Setter Property="Background"
                    Value="Transparent" />
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="models:SessionView">
            <Border Background="#181818"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20,16">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="4" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="0"
                           Width="4"
                           RadiusX="2"
                           RadiusY="2"
                           Fill="{Binding Track, Converter={StaticResource TrackBrush}}"
                           Margin="0,2,16,2" />

                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <StackPanel Orientation="Horizontal"
                              Spacing="8">
                    <Border Background="{Binding Track, Converter={StaticResource TrackBrush}}"
                            CornerRadius="10"
                            Padding="10,2">
                      <TextBlock Text="{Binding Track}"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="#0A0A0A" />
                    </Border>
                    <TextBlock Text="{Binding DayLabel}"
                               FontSize="12"
                               Opacity="0.6"
                               VerticalAlignment="Center"
                               Foreground="#E6E8EC" />
                  </StackPanel>

                  <TextBlock Text="{Binding Title}"
                             FontSize="18"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"
                             Foreground="#F5F5F5" />

                  <StackPanel Orientation="Horizontal"
                              Spacing="16"
                              Margin="0,4,0,0">
                    <TextBlock FontSize="12"
                               Opacity="0.7"
                               Foreground="#E6E8EC">
                      <Run Text="🕒 " />
                      <Run Text="{Binding TimeRange}" />
                    </TextBlock>
                    <TextBlock FontSize="12"
                               Opacity="0.7"
                               Foreground="#E6E8EC">
                      <Run Text="📍 " />
                      <Run Text="{Binding RoomId}" />
                    </TextBlock>
                    <TextBlock FontSize="12"
                               Opacity="0.7"
                               Foreground="#E6E8EC">
                      <Run Text="👤 " />
                      <Run Text="{Binding SpeakerSummary}" />
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="8"
                  Visibility="{Binding Sessions.None}">
        <TextBlock Text="⭐"
                   FontSize="48"
                   HorizontalAlignment="Center"
                   Opacity="0.5" />
        <TextBlock Text="No sessions yet"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#F5F5F5"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Tap the star on a session to add it to your agenda."
                   FontSize="13"
                   Opacity="0.7"
                   Foreground="#E6E8EC"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
