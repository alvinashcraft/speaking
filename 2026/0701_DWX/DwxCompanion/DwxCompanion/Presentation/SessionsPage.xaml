<UserControl x:Class="DwxCompanion.Presentation.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DwxCompanion.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI">
  <Grid utu:SafeArea.Insets="VisibleBounds"
        Padding="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <StackPanel Spacing="4">
      <TextBlock Text="Sessions"
                 FontSize="28"
                 FontWeight="SemiBold" />
      <TextBlock Text="Browse the full DWX 2026 program"
                 FontSize="14"
                 Opacity="0.7" />
    </StackPanel>
    <TextBlock Grid.Row="1"
               Text="(Session list coming soon)"
               FontSize="16"
               Opacity="0.5"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
  </Grid>
</UserControl>
