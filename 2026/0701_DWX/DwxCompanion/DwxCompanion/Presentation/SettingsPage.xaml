<UserControl x:Class="DwxCompanion.Presentation.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DwxCompanion.Presentation"
      xmlns:toolkit="using:Uno.Toolkit.UI"
      xmlns:utu="using:Uno.Toolkit.UI">
  <ScrollViewer Padding="32"
                Background="#0A0A0A"
                HorizontalScrollMode="Disabled">
    <StackPanel Spacing="32"
                MaxWidth="700"
                HorizontalAlignment="Left">

      <StackPanel Spacing="6">
        <TextBlock Text="Settings"
                   FontSize="32"
                   FontWeight="SemiBold"
                   Foreground="#F5F5F5" />
        <TextBlock Text="Customize your DWX Companion"
                   FontSize="14"
                   Opacity="0.7"
                   Foreground="#E6E8EC" />
      </StackPanel>

      <Border Background="#181818"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="12"
              Padding="24">
        <StackPanel Spacing="16">
          <StackPanel Spacing="4">
            <TextBlock Text="Time format"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#F5F5F5" />
            <TextBlock Text="Choose how session start and end times are displayed throughout the app."
                       FontSize="13"
                       Opacity="0.7"
                       Foreground="#E6E8EC"
                       TextWrapping="Wrap" />
          </StackPanel>

          <StackPanel Orientation="Horizontal"
                      Spacing="16"
                      VerticalAlignment="Center">
            <TextBlock Text="12-hour"
                       FontSize="14"
                       Foreground="#E6E8EC"
                       VerticalAlignment="Center" />
            <ToggleSwitch IsOn="{Binding Use24HourFormat, Mode=TwoWay}"
                          OnContent=""
                          OffContent="" />
            <TextBlock Text="24-hour"
                       FontSize="14"
                       Foreground="#E6E8EC"
                       VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="#181818"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="12"
              Padding="24">
        <StackPanel Spacing="6">
          <TextBlock Text="About"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#F5F5F5" />
          <TextBlock Text="DWX Companion · DWX 2026, Mannheim"
                     FontSize="13"
                     Opacity="0.8"
                     Foreground="#E6E8EC" />
          <TextBlock Text="Built with Uno Platform 6, MVUX, and the Material design system."
                     FontSize="12"
                     Opacity="0.6"
                     Foreground="#E6E8EC"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
