<!-- DWX 2026 brand palette
     Source: https://www.developer-world.com/dwx
     Accent: #C9F04C (electric lime), Secondary: #8ca835 (deep olive) -->
<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#8CA835</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#E5F5BD</Color>
      <Color x:Key="OnPrimaryContainerColor">#1B2900</Color>
      <Color x:Key="SecondaryColor">#1F1F1F</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E6E8EC</Color>
      <Color x:Key="OnSecondaryContainerColor">#1F1F1F</Color>
      <Color x:Key="TertiaryColor">#C9F04C</Color>
      <Color x:Key="OnTertiaryColor">#000000</Color>
      <Color x:Key="TertiaryContainerColor">#EDFBC2</Color>
      <Color x:Key="OnTertiaryContainerColor">#1B2900</Color>
      <Color x:Key="ErrorColor">#B3261E</Color>
      <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#410E0B</Color>
      <Color x:Key="BackgroundColor">#FCFCFC</Color>
      <Color x:Key="OnBackgroundColor">#1F1F1F</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1F1F1F</Color>
      <Color x:Key="SurfaceVariantColor">#E6E8EC</Color>
      <Color x:Key="OnSurfaceVariantColor">#454649</Color>
      <Color x:Key="OutlineColor">#76787C</Color>
      <Color x:Key="OnSurfaceInverseColor">#F1F1F1</Color>
      <Color x:Key="SurfaceInverseColor">#0A0A0A</Color>
      <Color x:Key="PrimaryInverseColor">#C9F04C</Color>
      <Color x:Key="SurfaceTintColor">#8CA835</Color>
      <Color x:Key="OutlineVariantColor">#C6C7CB</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <!-- DWX dark theme: lime accent on near-black surfaces -->
      <Color x:Key="PrimaryColor">#C9F04C</Color>
      <Color x:Key="OnPrimaryColor">#0A0A0A</Color>
      <Color x:Key="PrimaryContainerColor">#3D5400</Color>
      <Color x:Key="OnPrimaryContainerColor">#EDFBC2</Color>
      <Color x:Key="SecondaryColor">#E6E8EC</Color>
      <Color x:Key="OnSecondaryColor">#0A0A0A</Color>
      <Color x:Key="SecondaryContainerColor">#2A2A2A</Color>
      <Color x:Key="OnSecondaryContainerColor">#E6E8EC</Color>
      <Color x:Key="TertiaryColor">#8CA835</Color>
      <Color x:Key="OnTertiaryColor">#0A0A0A</Color>
      <Color x:Key="TertiaryContainerColor">#3D5400</Color>
      <Color x:Key="OnTertiaryContainerColor">#EDFBC2</Color>
      <Color x:Key="ErrorColor">#FFB4AB</Color>
      <Color x:Key="ErrorContainerColor">#93000A</Color>
      <Color x:Key="OnErrorColor">#690005</Color>
      <Color x:Key="OnErrorContainerColor">#FFDAD6</Color>
      <Color x:Key="BackgroundColor">#0A0A0A</Color>
      <Color x:Key="OnBackgroundColor">#E6E8EC</Color>
      <Color x:Key="SurfaceColor">#181818</Color>
      <Color x:Key="OnSurfaceColor">#E6E8EC</Color>
      <Color x:Key="SurfaceVariantColor">#1F1F1F</Color>
      <Color x:Key="OnSurfaceVariantColor">#C6C7CB</Color>
      <Color x:Key="OutlineColor">#8E9094</Color>
      <Color x:Key="OnSurfaceInverseColor">#1F1F1F</Color>
      <Color x:Key="SurfaceInverseColor">#E6E8EC</Color>
      <Color x:Key="PrimaryInverseColor">#8CA835</Color>
      <Color x:Key="SurfaceTintColor">#C9F04C</Color>
      <Color x:Key="OutlineVariantColor">#454649</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
